{
  "id": "contextclaw",
  "name": "ContextClaw",
  "description": "Classifies context by content type and applies retention policies. Files get truncated. Command output gets tailed. Your conversation stays intact.",
  "version": "1.0.0",
  "kind": "context-engine",
  "configSchema": {
    "type": "object",
    "properties": {
      "coldStorageDir": {
        "type": "string",
        "description": "Directory for cold-stored truncated content",
        "default": "~/.openclaw/workspace/memory/cold"
      },
      "wsPort": {
        "type": "integer",
        "description": "Port for WebSocket telemetry (Studio)",
        "default": 41234
      },
      "enableTelemetry": {
        "type": "boolean",
        "description": "Enable WebSocket telemetry broadcast",
        "default": true
      },
      "policies": {
        "type": "object",
        "description": "Per-type policy overrides (keyed by content type)",
        "additionalProperties": true
      }
    },
    "additionalProperties": false
  }
}