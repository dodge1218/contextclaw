{
  "id": "contextclaw",
  "name": "ContextClaw",
  "description": "Classifies context by content type and applies retention policies. Files get truncated. Command output gets tailed. Your conversation stays intact.",
  "version": "1.0.0",
  "kind": "context-engine",
  "configSchema": {
    "type": "object",
    "properties": {
      "coldStorageDir": {
        "type": "string",
        "description": "Directory for cold-stored truncated content",
        "default": "~/.openclaw/workspace/memory/cold"
      },
      "wsPort": {
        "type": "integer",
        "description": "Port for WebSocket telemetry (Studio)",
        "default": 41234
      },
      "enableTelemetry": {
        "type": "boolean",
        "description": "Enable WebSocket telemetry broadcast",
        "default": true
      },
      "activeModel": {
        "type": "string",
        "description": "Optional explicit provider/model id used for ContextClaw ledger estimates. Defaults to agents.defaults.model.primary."
      },
      "ledger": {
        "type": "object",
        "description": "Request ledger and pre-call cost-control settings",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "path": {
            "type": "string",
            "description": "JSONL path for request estimates and receipts",
            "default": "~/.openclaw/contextclaw/ledger.jsonl"
          },
          "maxCallsPerPrompt": {
            "type": "integer",
            "default": 8
          },
          "enforce": {
            "type": "boolean",
            "description": "When true, replace over-budget assembled contexts with a tiny synthetic gate message before provider execution.",
            "default": false
          },
          "maxEstimatedInputTokens": {
            "type": "integer",
            "default": 32000
          },
          "maxEstimatedCostUsd": {
            "type": "number",
            "default": 0.15
          },
          "blockDuplicateContexts": {
            "type": "boolean",
            "default": true
          },
          "blockPremiumUntilFinalPass": {
            "type": "boolean",
            "default": false
          },
          "estimatedOutputTokens": {
            "type": "integer",
            "default": 2048
          },
          "printReceipt": {
            "type": "boolean",
            "default": true
          },
          "pricing": {
            "type": "object",
            "description": "Optional per-model pricing override in dollars per million tokens",
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      },
      "policies": {
        "type": "object",
        "description": "Per-type policy overrides (keyed by content type)",
        "additionalProperties": true
      }
    },
    "additionalProperties": false
  }
}
