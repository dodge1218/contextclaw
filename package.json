{
  "name": "contextclaw",
  "version": "0.2.0",
  "description": "Stop sending Dockerfiles to your LLM 30 turns after you read them. Context management for AI agents.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "contextclaw": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "inspect": "node dist/inspector/server.js",
    "test": "vitest run",
    "test:plugin": "cd plugin && node --test",
    "test:all": "vitest run && cd plugin && node --test"
  },
  "keywords": [
    "openclaw",
    "context-window",
    "token-management",
    "ai-agent",
    "llm",
    "orchestration",
    "context-eviction",
    "prompt-caching",
    "anthropic",
    "claude",
    "openai",
    "multi-agent"
  ],
  "author": "DreamSiteBuilders <vonbrubeck@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dodge1218/contextclaw"
  },
  "dependencies": {
    "tiktoken": "^1.0.22",
    "fuse.js": "^7.0.0",
    "express": "^4.18.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0"
  }
}
