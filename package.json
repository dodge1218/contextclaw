{
  "name": "contextclaw",
  "version": "1.1.0",
  "description": "Cost defense with memory for agentic work: mission ledger, artifact store, budget governor, review feed, and context compression.",
  "main": "packages/core/dist/index.js",
  "types": "packages/core/dist/index.d.ts",
  "bin": {
    "cc": "./packages/core/dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p packages/core/tsconfig.json",
    "dev": "tsc --watch",
    "inspect": "node dist/inspector/server.js",
    "ledger": "npm run build && node packages/core/dist/cli.js ledger",
    "demo:mission-ledger": "bash prototypes/demo_mission_ledger.sh",
    "demo:mission-ledger:ts": "npm run build && node packages/core/dist/cli.js mission-demo",
    "demo:control-plane": "node scripts/demo-control-plane-ledger.js",
    "mvp:help": "python3 prototypes/contextclaw_mvp.py --help",
    "test": "vitest run packages/core/src",
    "test:plugin": "cd plugin && node --test",
    "test:all": "vitest run packages/core/src && cd plugin && node --test"
  },
  "keywords": [
    "openclaw",
    "context-window",
    "token-management",
    "ai-agent",
    "llm",
    "orchestration",
    "context-eviction",
    "prompt-caching",
    "anthropic",
    "claude",
    "openai",
    "multi-agent"
  ],
  "author": "DreamSiteBuilders <vonbrubeck@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dodge1218/contextclaw"
  },
  "dependencies": {
    "fuse.js": "^7.0.0",
    "tiktoken": "^1.0.22"
  },
  "optionalDependencies": {
    "express": "^4.18.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
